-- DATE: May 22, 2025



WITH landing_data AS (
    SELECT
        InstrumentID
        ,REPLACE(
            InstrumentID,
            SUBSTRING(
                InstrumentID,
                instr(InstrumentID, '_'),
                length(InstrumentID)
            ),
            ''
        ) AS InstrumentType
        ,REPLACE(
            InstrumentID,
            LEFT(InstrumentID, instr(InstrumentID, '_')),
